# ── Copy to .env (docker compose reads .env automatically): cp .env.example .env ──

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops_secret_change_me
POSTGRES_DB=mlops
POSTGRES_PORT=5432
# DSN used by inference (psycopg2 driver). The trainer compose service derives its own
# psycopg3 DSN from POSTGRES_* vars directly — no separate var needed in .env.
DATABASE_URL=postgresql+psycopg2://mlops:mlops_secret_change_me@postgres:5432/mlops

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Paths (inside containers) ────────────────────────────────────────────────
MODELS_DIR=/models
DATA_DIR=/data

# ── Streamer ─────────────────────────────────────────────────────────────────
START_DATASET=fraud          # fraud | iot | intrusion
START_INTERVAL_MS=500        # delay between streamed rows (controllable from the UI)

# ── Inference ────────────────────────────────────────────────────────────────
INFERENCE_PORT=8000

# ── Trainer (live Training Lab) ──────────────────────────────────────────────
TRAINER_PORT=8001
INFERENCE_URL=http://inference:8000   # trainer calls /reload here after training

# ── Dashboard (Next.js) ──────────────────────────────────────────────────────
DASHBOARD_PORT=3000
# Browser-reachable URLs (host ports). For local docker compose these map to localhost.
NEXT_PUBLIC_INFERENCE_URL=http://localhost:8000
NEXT_PUBLIC_TRAINER_URL=http://localhost:8001
# Server-side (RSC) URL to reach inference over the Docker network — not browser-facing.
INFERENCE_INTERNAL_URL=http://inference:8000
